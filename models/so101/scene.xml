<mujoco model="so101_scene">
    <include file="so101_new_calib.xml" />
    <option timestep="0.001"/>
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="1 1 1 1" />
        <global azimuth="160" elevation="-20" />
    </visual>
    <asset>
        <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="512"
            height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.85 0.85 0.85"
            rgb2="0.75 0.75 0.75"
            markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
            reflectance="0.2" />
    </asset>
    <worldbody>
        <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />

        <!-- Overhead camera (used for planning / depth projection) -->
        <camera name="overhead_cam"
                pos="0.3 0.0 0.8"
                mode="fixed"
                fovy="60"/>

        <!-- Front-view camera (useful for recording the pick motion) -->
        <!-- pos=(0.8, 0, 0.3): 80 cm in front of robot, 30 cm high           -->
        <!-- xyaxes computed so that -Z_cam points directly at world origin:   -->
        <!--   right=(0,1,0)  up=(-0.3511,0,0.9363)  fwd=(-0.9363,0,-0.3511) -->
        <camera name="front_cam"
                pos="0.8 0.0 0.3"
                mode="fixed"
                xyaxes="0 1 0 -0.3511 0 0.9363"
                fovy="60"/>

        <!-- Test object: red cube -->
        <body name="red_cube" pos="0.25 0.08 0.02">
            <freejoint name="red_cube_joint"/>
            <geom type="box" size="0.02 0.02 0.02"
                  rgba="0.8 0.1 0.1 1"
                  mass="0.05"
                  friction="2 0.5 0.01"
                  condim="4"
                  contype="1" conaffinity="1"/>
        </body>

        <body name="blue_box" pos="0.25 -0.10 0.0">
            <freejoint name="blue_box_joint"/>
            <geom type="box" size="0.04 0.04 0.001" rgba="0.1 0.1 0.8 1" mass="0.1" friction="1 0.005 0.0001" condim="4" pos="0 0 0.001"/>
            <geom type="box" size="0.001 0.04 0.03" rgba="0.1 0.1 0.8 1" mass="0.05" pos="-0.04 0 0.03"/>
            <geom type="box" size="0.001 0.04 0.03" rgba="0.1 0.1 0.8 1" mass="0.05" pos="0.04 0 0.03"/>
            <geom type="box" size="0.04 0.001 0.03" rgba="0.1 0.1 0.8 1" mass="0.05" pos="0 -0.04 0.03"/>
            <geom type="box" size="0.04 0.001 0.03" rgba="0.1 0.1 0.8 1" mass="0.05" pos="0 0.04 0.03"/>
        </body>
    </worldbody>
</mujoco>
